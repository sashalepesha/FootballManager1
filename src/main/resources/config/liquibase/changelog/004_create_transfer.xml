<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="004-create-transfer" author="sasha">

    <createTable tableName="transfer">

      <column name="id" type="BIGINT" autoIncrement="true">
        <constraints primaryKey="true"
                     nullable="false"/>
      </column>

      <column name="player_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="from_team_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="to_team_id" type="BIGINT">
        <constraints nullable="false"/>
      </column>

      <column name="transfer_fee" type="DECIMAL(21,2)">
        <constraints nullable="false"/>
      </column>

      <column name="transfer_date" type="DATE">
        <constraints nullable="false"/>
      </column>

    </createTable>

    <addForeignKeyConstraint
      baseTableName="transfer"
      baseColumnNames="player_id"
      referencedTableName="player"
      referencedColumnNames="id"
      constraintName="fk_transfer_player"/>

    <addForeignKeyConstraint
      baseTableName="transfer"
      baseColumnNames="from_team_id"
      referencedTableName="team"
      referencedColumnNames="id"
      constraintName="fk_transfer_from_team"/>

    <addForeignKeyConstraint
      baseTableName="transfer"
      baseColumnNames="to_team_id"
      referencedTableName="team"
      referencedColumnNames="id"
      constraintName="fk_transfer_to_team"/>

  </changeSet>

</databaseChangeLog>
