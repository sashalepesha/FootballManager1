<?xml version="1.0" encoding="utf-8"?>

<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="
      http://www.liquibase.org/xml/ns/dbchangelog
      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="003-create-game" author="sasha">

    <createTable tableName="game">

      <column name="id" type="bigserial">
        <constraints primaryKey="true"/>
      </column>

      <column name="match_date" type="timestamp">
        <constraints nullable="false"/>
      </column>

      <column name="stadium" type="varchar(255)"/>

      <column name="home_score" type="integer"/>

      <column name="away_score" type="integer"/>

      <column name="home_team_id" type="bigint">
        <constraints nullable="false"/>
      </column>

      <column name="away_team_id" type="bigint">
        <constraints nullable="false"/>
      </column>

    </createTable>

    <addForeignKeyConstraint
      baseTableName="game"
      baseColumnNames="home_team_id"
      referencedTableName="team"
      referencedColumnNames="id"
      constraintName="fk_game_home_team"/>

    <addForeignKeyConstraint
      baseTableName="game"
      baseColumnNames="away_team_id"
      referencedTableName="team"
      referencedColumnNames="id"
      constraintName="fk_game_away_team"/>

  </changeSet>

</databaseChangeLog>
